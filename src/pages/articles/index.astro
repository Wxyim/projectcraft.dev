---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentList from '@/components/ContentList.astro';
import { collections } from '@/config/site';
import { getPublishedCollection, type AnyEntry } from '@/utils/content';

const meta = collections.articles;
const entries = await getPublishedCollection('articles');

// Load connection scope for real connection counts
const allEntries: AnyEntry[] = [
  ...(await getPublishedCollection('notes')),
  ...(await getPublishedCollection('garden')),
  ...(await getPublishedCollection('articles')),
];
---

<BaseLayout title={meta.title} description={meta.description}>
  <section class="container hero">
    <h1 class="page-title">{meta.title}</h1>
    <p class="lede">{meta.description}</p>
  </section>
  <section class="container section">
    <ContentList entries={entries} allEntries={allEntries} />
  </section>
</BaseLayout>
