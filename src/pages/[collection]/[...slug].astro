---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Giscus from '@/components/Giscus.astro';
import { ArrowUpRight } from '@lucide/astro';
import { collectionLabel, formatDate, getEntryUrl, getExplicitRelated, getTagRelated, getUpstream, type CollectionName, type AnyEntry } from '@/utils/content';
import { site } from '@/config/site';

const { collection, slug } = Astro.params;
if (!collection || !slug) return new Response('Not found', { status: 404 });

const entries = await getCollection(collection as CollectionName, ({ data }) => !data.draft);
const entry = entries.find((e) => e.id === slug);
if (!entry) return new Response('Not found', { status: 404 });

const { Content, headings } = await render(entry);
const title = entry.data.seoTitle ?? entry.data.title;
const description = entry.data.seoDescription ?? entry.data.description;

// Reading time estimate
const bodyText = entry.body ?? '';
const wordCount = bodyText.replace(/<[^>]*>/g, '').replace(/[#*`~\[\]()!_\-=|{}\:;'"",.<>?\/\\]/g, ' ').split(/\s+/).filter(Boolean).length;
// Chinese text: count characters instead
const chineseChars = (bodyText.match(/[一-鿿㐀-䶿]/g) || []).length;
const effectiveWords = wordCount + Math.floor(chineseChars / 2);
const readingTimeMin = Math.max(1, Math.ceil(effectiveWords / 200));

function entryStatusIcon(status: string): string {
  if (status === 'evergreen') return '🌳';
  if (status === 'budding') return '🌿';
  return '🌱';
}

// TOC: filter h2/h3 with slugs
const toc = headings.filter((h) => h.depth <= 3 && h.slug).slice(0, 24);

const allEntries: AnyEntry[] = [
  ...(await getCollection('notes', ({ data }) => !data.draft)),
  ...(await getCollection('garden', ({ data }) => !data.draft)),
  ...(await getCollection('articles', ({ data }) => !data.draft)),
];

// Parse body for implicit backlinks (links to other entries)
function extractBodyLinks(rawBody: string): string[] {
  const links: string[] = [];
  const re = /\[([^\]]*)\]\(\/([^)\s]+)\/?\)/g;
  let m;
  while ((m = re.exec(rawBody)) !== null) {
    links.push(m[2]); // e.g. "notes/redis" or "articles/some-post"
  }
  return links;
}
const bodyLinks = entry.body ? extractBodyLinks(entry.body) : [];
const implicitRelated = allEntries.filter((e) =>
  bodyLinks.some((link) => {
    const full = `${e.collection}/${e.id}`;
    return link === full || link === e.id;
  })
);

const explicitRelated = getExplicitRelated(entry as AnyEntry, allEntries);
const tagRelated = getTagRelated(entry as AnyEntry, allEntries, 4);
const related = [...explicitRelated, ...implicitRelated, ...tagRelated].filter(
  (e, i, arr) => arr.findIndex((x) => x.id === e.id) === i
).slice(0, 6);
const upstream = getUpstream(entry as AnyEntry, allEntries);
const relatedIds = new Set(related.map((e) => `${e.collection}/${e.id}`));
const suggestions = getTagRelated(entry as AnyEntry, allEntries, 6)
  .filter((e) => !relatedIds.has(`${e.collection}/${e.id}`))
  .slice(0, 3);
---

<BaseLayout title={title} description={description} image={entry.data.image} type="article">
  <article class="container prose">
    <div class="reading-progress" id="reading-progress"><div class="reading-progress-bar" id="reading-progress-bar"></div></div>
    <div class="meta">
      <a href={`/${entry.collection}/`}>{collectionLabel(entry.collection as CollectionName)}</a>
      {collection === 'garden' && (
        <span class={`garden-status garden-status-${(entry.data as any).status || 'seedling'}`}>
          {entryStatusIcon((entry.data as any).status || 'seedling')} {(entry.data as any).status === 'evergreen' ? 'Evergreen' : (entry.data as any).status === 'budding' ? 'Budding' : 'Seedling'}
        </span>
      )}
      <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
      {entry.data.updatedDate && <span>Last tended {formatDate(entry.data.updatedDate)}</span>}
      <span class="reading-time" title={`约 ${effectiveWords.toLocaleString()} 字`}>📖 {readingTimeMin} 分钟</span>
    </div>
    <h1>{entry.data.title}</h1>
    {entry.data.image && <img class="cover-image" src={entry.data.image} alt={entry.data.title} />}
    {entry.data.description && <p class="lede">{entry.data.description}</p>}
    {entry.data.tags.length > 0 && (
      <div class="tags" aria-label="Tags" style="margin-top: 8px;">
        {entry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    )}
    {(collection === 'notes' || collection === 'articles' || collection === 'garden') && (
      <div class="garden-cta">
        <a href="/garden/#garden-tabs">🌱 在数字花园中查看关联</a>
      </div>
    )}
    <Content />
    <footer class="prose-footer">
      {(related.length > 0 || upstream.length > 0) && (
        <nav class="related-notes" aria-label="Related notes">
          {upstream.length > 0 && (
            <div class="related-group">
              <h3>← 上游知识</h3>
              <div class="related-links">
                {upstream.map((r) => <a href={getEntryUrl(r)}>{r.data.title}</a>)}
              </div>
            </div>
          )}
          {related.length > 0 && (
            <div class="related-group">
              <h3>→ 相关笔记</h3>
              <div class="related-links">
                {related.map((r) => <a href={getEntryUrl(r)}>{r.data.title}</a>)}
              </div>
            </div>
          )}
        </nav>
      )}
      {suggestions.length > 0 && (
        <div class="suggestions">
          <p class="suggestions-hint">💡 写作建议：这些标签关联的条目尚未加入 related，可以手动添加：</p>
          <div class="related-links">
            {suggestions.map((r) => (
              <a href={getEntryUrl(r)}>{r.data.title}<span class="suggest-ref"> → related: &quot;{r.collection}/{r.id}&quot;</span></a>
            ))}
          </div>
        </div>
      )}
      <div class="share-section">
        <p class="share-label">📤 分享这篇文章</p>
        <div class="share-buttons">
          <button class="share-btn" id="copy-link-btn" title="复制链接" aria-label="复制链接">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span>复制链接</span>
          </button>
          <a class="share-btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(new URL(getEntryUrl(entry), site.url).toString())}`} target="_blank" rel="noopener noreferrer" title="分享到 X" aria-label="分享到 X">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <span>X</span>
          </a>
          <a class="share-btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(new URL(getEntryUrl(entry), site.url).toString())}`} target="_blank" rel="noopener noreferrer" title="分享到 LinkedIn" aria-label="分享到 LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <span>LinkedIn</span>
          </a>
        </div>
      </div>
      <p><a href={getEntryUrl(entry)}>Permalink</a> · <small>内容采用 <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="license" target="_blank">CC BY-SA 4.0 <ArrowUpRight size={12} stroke-width={2} /></a> 许可</small></p>
      <div class="giscus-wrapper"><Giscus /></div>
    </footer>
  </article>
  {toc.length > 0 && (
    <aside class="toc-float" id="toc-float" aria-label="Table of contents">
      <button class="float-btn toc-btn" id="toc-btn" type="button" aria-expanded="false" title="目录">☰</button>
      <nav class="toc-panel" id="toc-panel">
        <ol>
          {toc.map((h) => (
            <li class={`toc-depth-${h.depth}`}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    </aside>
    )}
  <button class="float-btn scroll-control" id="scroll-control" type="button" title="返回顶部" aria-label="返回顶部">↑</button>
  <script>
    (function() {
      // Position float buttons relative to content area
      var MAX_WIDTH = 1080;
      var GAP = 20;
      function updatePositions() {
        var vw = window.innerWidth;
        var right = vw <= MAX_WIDTH + GAP * 2 ? GAP : Math.floor((vw - MAX_WIDTH) / 2) + GAP;
        var btns = document.querySelectorAll('.float-btn');
        btns.forEach(function(b) { b.style.right = right + 'px'; });
        var panel = document.getElementById('toc-panel');
        if (panel) panel.style.right = (right + 48) + 'px';
      }
      updatePositions();
      window.addEventListener('resize', updatePositions);

      var float = document.getElementById('toc-float');
      var btn = document.getElementById('toc-btn');
      var panel = document.getElementById('toc-panel');
      var backTop = document.getElementById('scroll-control');

      // TOC toggle (only if TOC exists)
      var expanded = false;
      if (float && btn && panel) {
        btn.addEventListener('click', function() {
          expanded = !expanded;
          float.dataset.expanded = expanded ? 'true' : 'false';
          btn.setAttribute('aria-expanded', String(expanded));
        });
        panel.querySelectorAll('a').forEach(function(link) {
          link.addEventListener('click', function() {
            expanded = false;
            float.dataset.expanded = 'false';
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      }

      function close() {
        if (!float) return;
        expanded = false;
        float.dataset.expanded = 'false';
        btn.setAttribute('aria-expanded', 'false');
      }

      // Close panel when clicking outside
      document.addEventListener('click', function(e) {
        if (expanded && float && !float.contains(e.target)) {
          close();
        }
      });

      // Scroll handler: auto-close TOC on scroll
        var lastScrollY = 0;
        window.addEventListener('scroll', function() {
          var scrollY = window.scrollY;
          if (expanded && scrollY !== lastScrollY) {
            close();
          }
          lastScrollY = scrollY;
        }, { passive: true });

        // Back to top: click + scroll-based visibility
        if (backTop) {
          backTop.addEventListener('click', function() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });

          // Keep this independent of IntersectionObserver. Android Firefox can
          // miss observer changes for an absolutely positioned body child.
          function updateBackTopVisibility() {
            var scrollTop = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;
            backTop.classList.toggle('visible', scrollTop > window.innerHeight);
          }

          updateBackTopVisibility();
          window.addEventListener('scroll', updateBackTopVisibility, { passive: true });
          window.addEventListener('resize', updateBackTopVisibility);
        }

        // Scroll highlight: find topmost visible heading
        var tocLinks = panel ? panel.querySelectorAll('a') : [];
        var headings = Array.from(tocLinks).map(function(a) { return document.getElementById(a.getAttribute('href')?.slice(1) || ''); }).filter(Boolean);
        headings.sort(function(a, b) { return a.offsetTop - b.offsetTop; });

        // Compute section boundaries: each heading[i]'s section spans from its offsetTop
        // to heading[i+1]'s offsetTop (or page end for the last). Highlight the section
        // that occupies the largest portion of the viewport.
        function updateHighlight() {
          var vh = window.innerHeight;
          var scrollTop = window.scrollY;
          var viewTop = scrollTop;
          var viewBottom = scrollTop + vh;

          var bestId = null, bestOverlap = 0;
          for (var i = 0; i < headings.length; i++) {
            var sectionTop = headings[i].offsetTop;
            var sectionBottom = i + 1 < headings.length ? headings[i + 1].offsetTop : document.body.scrollHeight;
            // Overlap between viewport and section
            var overlapTop = Math.max(viewTop, sectionTop);
            var overlapBottom = Math.min(viewBottom, sectionBottom);
            var overlap = Math.max(0, overlapBottom - overlapTop);
            if (overlap > bestOverlap) {
              bestOverlap = overlap;
              bestId = headings[i].id;
            }
          }

          tocLinks.forEach(function(a) { a.style.color = ''; });
          if (bestId && bestOverlap > 0 && panel) {
            var link = panel.querySelector('a[href="#' + CSS.escape(bestId) + '"]');
            if (link) link.style.color = 'var(--accent)';
          }
        }

        if (headings.length > 0) {
          window.addEventListener('scroll', function() {
            requestAnimationFrame(updateHighlight);
          }, { passive: true });
          updateHighlight();
        }

        // --- Reading progress bar ---
        var progressBar = document.getElementById('reading-progress-bar');
        if (progressBar) {
          var bar = progressBar;
          window.addEventListener('scroll', function() {
            requestAnimationFrame(function() {
              var scrollTop = window.pageYOffset || document.documentElement.scrollTop || 0;
              var docHeight = document.documentElement.scrollHeight - window.innerHeight;
              var progress = docHeight > 0 ? Math.min(1, Math.max(0, scrollTop / docHeight)) : 0;
              bar.style.transform = 'scaleX(' + progress + ')';
            });
          }, { passive: true });
        }

        // --- Code block copy buttons ---
        var codeBlocks = document.querySelectorAll('.prose pre');
        codeBlocks.forEach(function(pre) {
          var parent = pre.parentNode;
          if (!parent) return;
          var wrapper = document.createElement('div');
          wrapper.className = 'code-block-wrapper';
          parent.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          var copyBtn = document.createElement('button');
          copyBtn.className = 'copy-code-btn';
          copyBtn.setAttribute('aria-label', '复制代码');
          copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
          wrapper.appendChild(copyBtn);

          copyBtn.addEventListener('click', function() {
            var code = pre.querySelector('code');
            var text = code ? code.textContent || '' : pre.textContent || '';
            navigator.clipboard.writeText(text).then(function() {
              copyBtn.classList.add('copied');
              copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
              setTimeout(function() {
                copyBtn.classList.remove('copied');
                copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
              }, 2000);
            }).catch(function() {
              var ta = document.createElement('textarea');
              ta.value = text;
              ta.style.position = 'fixed';
              ta.style.opacity = '0';
              document.body.appendChild(ta);
              ta.select();
              document.execCommand('copy');
              document.body.removeChild(ta);
              copyBtn.classList.add('copied');
              setTimeout(function() { copyBtn.classList.remove('copied'); }, 2000);
            });
          });
        });

        // --- Callout detection: add class to emoji-prefixed blockquotes ---
        var blockquotes = document.querySelectorAll('.prose blockquote');
        blockquotes.forEach(function(bq) {
          var firstP = bq.querySelector('p:first-child');
          if (!firstP) return;
          var text = firstP.textContent || '';
          if (/^💡/.test(text)) bq.classList.add('callout-info');
          else if (/^⚠️/.test(text)) bq.classList.add('callout-warning');
          else if (/^✅/.test(text)) bq.classList.add('callout-success');
          else if (/^❌|^🚫/.test(text)) bq.classList.add('callout-danger');
          else if (/^💭/.test(text)) bq.classList.add('callout-tip');
        });

        // --- Share: copy link button ---
        var copyLinkBtn = document.getElementById('copy-link-btn');
        if (copyLinkBtn) {
          var shareBtn = copyLinkBtn;
          shareBtn.addEventListener('click', function() {
            navigator.clipboard.writeText(window.location.href).then(function() {
              var span = shareBtn.querySelector('span');
              if (span) {
                var orig = span.textContent || '';
                var s = span;
                var b = shareBtn;
                s.textContent = '已复制!';
                b.classList.add('copied');
                setTimeout(function() {
                  s.textContent = orig;
                  b.classList.remove('copied');
                }, 2000);
              }
            }).catch(function() {
              var ta = document.createElement('textarea');
              ta.value = window.location.href;
              ta.style.position = 'fixed';
              ta.style.opacity = '0';
              document.body.appendChild(ta);
              ta.select();
              document.execCommand('copy');
              document.body.removeChild(ta);
            });
          });
        }
          })();
        </script>
</BaseLayout>

<style>
  /* --- Reading progress bar --- */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: transparent;
    z-index: 100;
    pointer-events: none;
  }

  .reading-progress-bar {
    height: 100%;
    width: 100%;
    background: var(--accent);
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 0.1s linear;
  }

  /* --- Reading time --- */
  .reading-time {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.82rem;
    color: var(--muted);
    font-weight: 500;
  }

  .cover-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
    margin: 4px 0 20px;
  }

  .related-notes {
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .related-group {
    margin-bottom: 14px;
  }

  .related-group h3 {
    margin: 0 0 8px;
    font-size: 0.9rem;
    color: var(--muted);
    font-weight: 600;
  }

  .related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .related-links a {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 12px;
    font-size: 0.9rem;
    text-decoration: none;
    background: var(--bg-soft);
  }

  .related-links a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Floating buttons — unified style */
  .float-btn {
    position: fixed;
    z-index: 50;
    width: 42px;
    height: 42px;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    cursor: pointer;
    font-size: 1.05rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: box-shadow 0.25s, opacity 0.25s;
  }

  .float-btn:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
  }

  /* TOC button */
  .toc-btn {
    bottom: 80px;
    opacity: 0.7;
  }

  .toc-btn:hover {
    opacity: 1;
  }

  .toc-btn:hover {
    opacity: 1;
  }

  /* TOC panel */
  .toc-panel {
    position: fixed;
    bottom: 80px;
    width: 260px;
    max-height: 0;
    overflow: hidden;
    background: var(--bg);
    border: 0;
    border-radius: 12px;
    box-shadow: none;
    transition: max-height 0.25s ease, padding 0.25s ease, border 0.25s ease, box-shadow 0.25s ease;
    z-index: 49;
  }

  .toc-float[data-expanded="true"] .toc-panel {
    max-height: min(400px, 70vh);
    overflow-y: auto;
    padding: 8px 0;
    border: 1px solid var(--line);
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
  }

  .toc-panel ol {
    margin: 0;
    padding: 0 18px;
    list-style: none;
  }

  .toc-panel li {
    margin-bottom: 4px;
    line-height: 1.4;
  }

  .toc-depth-2 { font-weight: 600; }
  .toc-depth-3 { padding-left: 14px; font-size: 0.88rem; }

  .toc-panel a {
    display: block;
    text-decoration: none;
    color: var(--muted);
    transition: color 0.15s;
    padding: 3px 0;
    font-size: 0.85rem;
  }

  .toc-panel a:hover { color: var(--accent); }

  /* Back to top — hidden until JS adds .visible after scrolling past one viewport */
  .scroll-control {
    bottom: 30px;
    opacity: 0;
    pointer-events: none;
    font-weight: 700;
  }

  .scroll-control.visible {
    opacity: 0.7;
    pointer-events: auto;
  }

  .scroll-control.visible:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .toc-panel { width: 220px; }
    .scroll-control { bottom: 20px; }
  }

  @media (max-width: 480px) {
    .toc-panel {
      width: calc(100vw - 64px);
    }
  }

  .garden-status {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.82rem;
    font-weight: 650;
    border-radius: 999px;
    padding: 2px 10px;
  }

  .garden-status-seedling { background: #faf0e6; color: #b8860b; }
  .garden-status-budding  { background: #e8f8e0; color: #6b8e23; }
  .garden-status-evergreen { background: #e0f0e8; color: #2d7a2d; }

  :root.dark .garden-status-seedling { background: #2a2218; color: #d4a574; }
  :root.dark .garden-status-budding  { background: #1a2818; color: #bfeb5f; }
  :root.dark .garden-status-evergreen { background: #182820; color: #5aad5a; }

  .garden-cta {
    margin: 12px 0 20px;
  }

  .garden-cta a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    border: 1px dashed var(--line);
    border-radius: 999px;
    padding: 4px 12px;
    transition: all 0.15s;
  }

  .garden-cta a:hover {
