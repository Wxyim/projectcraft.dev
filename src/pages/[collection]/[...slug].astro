---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Giscus from '@/components/Giscus.astro';
import { ArrowUpRight } from '@lucide/astro';
import { collectionLabel, formatDate, getEntryUrl, getExplicitRelated, getTagRelated, getUpstream, type CollectionName, type AnyEntry } from '@/utils/content';

const { collection, slug } = Astro.params;
if (!collection || !slug) return new Response('Not found', { status: 404 });

const entries = await getCollection(collection as CollectionName, ({ data }) => !data.draft);
const entry = entries.find((e) => e.id === slug);
if (!entry) return new Response('Not found', { status: 404 });

const { Content, headings } = await render(entry);
const title = entry.data.seoTitle ?? entry.data.title;
const description = entry.data.seoDescription ?? entry.data.description;

// TOC: filter h2/h3 with slugs
const toc = headings.filter((h) => h.depth <= 3 && h.slug).slice(0, 12);

const allEntries: AnyEntry[] = [
  ...(await getCollection('notes', ({ data }) => !data.draft)),
  ...(await getCollection('garden', ({ data }) => !data.draft)),
  ...(await getCollection('articles', ({ data }) => !data.draft)),
];

// Parse body for implicit backlinks (links to other entries)
function extractBodyLinks(rawBody: string): string[] {
  const links: string[] = [];
  const re = /\[([^\]]*)\]\(\/([^)\s]+)\/?\)/g;
  let m;
  while ((m = re.exec(rawBody)) !== null) {
    links.push(m[2]); // e.g. "notes/redis" or "articles/some-post"
  }
  return links;
}
const bodyLinks = entry.body ? extractBodyLinks(entry.body) : [];
const implicitRelated = allEntries.filter((e) =>
  bodyLinks.some((link) => {
    const full = `${e.collection}/${e.id}`;
    return link === full || link === e.id;
  })
);

const explicitRelated = getExplicitRelated(entry as AnyEntry, allEntries);
const tagRelated = getTagRelated(entry as AnyEntry, allEntries, 4);
const related = [...explicitRelated, ...implicitRelated, ...tagRelated].filter(
  (e, i, arr) => arr.findIndex((x) => x.id === e.id) === i
).slice(0, 6);
const upstream = getUpstream(entry as AnyEntry, allEntries);
const relatedIds = new Set(related.map((e) => `${e.collection}/${e.id}`));
const suggestions = getTagRelated(entry as AnyEntry, allEntries, 6)
  .filter((e) => !relatedIds.has(`${e.collection}/${e.id}`))
  .slice(0, 3);
---

<BaseLayout title={title} description={description} image={entry.data.image} type="article">
  <article class="container prose">
    <div class="meta">
      <a href={`/${entry.collection}/`}>{collectionLabel(entry.collection as CollectionName)}</a>
      <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
      {entry.data.updatedDate && <span>Updated {formatDate(entry.data.updatedDate)}</span>}
    </div>
    <h1>{entry.data.title}</h1>
    {entry.data.image && <img class="cover-image" src={entry.data.image} alt={entry.data.title} />}
    {entry.data.description && <p class="lede">{entry.data.description}</p>}
    {entry.data.tags.length > 0 && (
      <div class="tags" aria-label="Tags" style="margin-top: 8px;">
        {entry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    )}
    <div class="garden-cta">
      <a href="/garden/">🌱 在数字花园中查看关联</a>
    </div>
    {toc.length > 0 && (
      <nav class="toc" aria-label="Table of contents" id="toc-nav" data-expanded="false">
        <button class="toc-toggle" type="button" aria-expanded="false">
          <h2>目录</h2>
          <span class="toc-arrow">▸</span>
        </button>
        <ol class="toc-list">
          {toc.map((h) => (
            <li class={`toc-depth-${h.depth}`}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}
    <Content />
    <footer class="prose-footer">
      {(related.length > 0 || upstream.length > 0) && (
        <nav class="related-notes" aria-label="Related notes">
          {upstream.length > 0 && (
            <div class="related-group">
              <h3>← 上游知识</h3>
              <div class="related-links">
                {upstream.map((r) => <a href={getEntryUrl(r)}>{r.data.title}</a>)}
              </div>
            </div>
          )}
          {related.length > 0 && (
            <div class="related-group">
              <h3>→ 相关笔记</h3>
              <div class="related-links">
                {related.map((r) => <a href={getEntryUrl(r)}>{r.data.title}</a>)}
              </div>
            </div>
          )}
        </nav>
      )}
      {suggestions.length > 0 && (
        <div class="suggestions">
          <p class="suggestions-hint">💡 写作建议：这些标签关联的条目尚未加入 related，可以手动添加：</p>
          <div class="related-links">
            {suggestions.map((r) => (
              <a href={getEntryUrl(r)}>{r.data.title}<span class="suggest-ref"> → related: &quot;{r.collection}/{r.id}&quot;</span></a>
            ))}
          </div>
        </div>
      )}
      <p><a href={getEntryUrl(entry)}>Permalink</a> · <small>内容采用 <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="license" target="_blank">CC BY-SA 4.0 <ArrowUpRight size={12} stroke-width={2} /></a> 许可</small></p>
      <div class="giscus-wrapper"><Giscus /></div>
    </footer>
  </article>
  {toc.length > 0 && (
    <script>
      // Toggle expand/collapse
      (function() {
        const nav = document.getElementById('toc-nav');
        const btn = nav?.querySelector('.toc-toggle');
        if (!nav || !btn) return;
        btn.addEventListener('click', function() {
          const expanded = nav.dataset.expanded === 'true';
          nav.dataset.expanded = expanded ? 'false' : 'true';
          btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        });
      })();

      // Scroll highlight
      const tocLinks = document.querySelectorAll('.toc a');
      const headings = Array.from(tocLinks).map((a) => document.getElementById(a.getAttribute('href')?.slice(1) || '')).filter(Boolean);
      const observer = new IntersectionObserver((entries) => {
        let activeId = null;
        for (const e of entries) {
          if (e.isIntersecting) { activeId = e.target.id; break; }
        }
        if (activeId) {
          tocLinks.forEach((a) => a.style.color = '');
          const active = document.querySelector('.toc a[href="#' + CSS.escape(activeId) + '"]');
          if (active) active.style.color = 'var(--accent)';
        }
      }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
      headings.forEach((h) => observer.observe(h));
    </script>
  )}
</BaseLayout>

<style>
  .cover-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
    margin: 4px 0 20px;
  }

  .related-notes {
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .related-group {
    margin-bottom: 14px;
  }

  .related-group h3 {
    margin: 0 0 8px;
    font-size: 0.9rem;
    color: var(--muted);
    font-weight: 600;
  }

  .related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .related-links a {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 12px;
    font-size: 0.9rem;
    text-decoration: none;
    background: var(--bg-soft);
  }

  .related-links a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .toc {
    margin: 0 0 24px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
    overflow: hidden;
  }

  .toc-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 10px 18px;
    border: none;
    background: none;
    cursor: pointer;
    font: inherit;
    color: inherit;
  }

  .toc-toggle h2 {
    margin: 0;
    font-size: 0.82rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .toc-arrow {
    font-size: 0.7rem;
    transition: transform 0.2s;
    color: var(--muted);
  }

  .toc[data-expanded="true"] .toc-arrow {
    transform: rotate(90deg);
  }

  .toc-list {
    margin: 0;
    padding: 0 18px;
    list-style: none;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.25s ease, padding-bottom 0.25s ease;
  }

  .toc[data-expanded="true"] .toc-list {
    max-height: 400px;
    overflow-y: auto;
    padding-bottom: 14px;
  }

  .toc li {
    margin-bottom: 4px;
    line-height: 1.4;
  }

  .toc-depth-2 { font-weight: 600; }
  .toc-depth-3 { padding-left: 16px; font-size: 0.9rem; }

  .toc a {
    display: block;
    text-decoration: none;
    color: var(--muted);
    transition: color 0.15s;
    padding: 2px 0;
  }

  .toc a:hover { color: var(--accent); }

  .garden-cta {
    margin: 12px 0 20px;
  }

  .garden-cta a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    border: 1px dashed var(--line);
    border-radius: 999px;
    padding: 4px 12px;
    transition: all 0.15s;
  }

  .garden-cta a:hover {
    border-color: var(--accent);
    color: var(--accent);
    border-style: solid;
  }

  .suggestions {
    margin: 0 0 20px;
    padding: 14px 16px;
    border: 1px dashed var(--line);
    border-radius: 10px;
    background: var(--bg-soft);
  }

  .suggestions-hint {
    margin: 0 0 10px;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .suggest-ref {
    display: block;
    font-size: 0.72rem;
    color: var(--muted);
    font-weight: 400;
    font-family: var(--font-mono, monospace);
  }

  .suggestions .related-links a {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 6px 14px;
    border-radius: 10px;
  }
</style>
