---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Giscus from '@/components/Giscus.astro';
import { ArrowUpRight } from '@lucide/astro';
import { collectionLabel, formatDate, getEntryUrl, getExplicitRelated, getTagRelated, getUpstream, type CollectionName, type AnyEntry } from '@/utils/content';

const { collection, slug } = Astro.params;
if (!collection || !slug) return new Response('Not found', { status: 404 });

const entries = await getCollection(collection as CollectionName, ({ data }) => !data.draft);
const entry = entries.find((e) => e.id === slug);
if (!entry) return new Response('Not found', { status: 404 });

const { Content } = await render(entry);
const title = entry.data.seoTitle ?? entry.data.title;
const description = entry.data.seoDescription ?? entry.data.description;

const allEntries: AnyEntry[] = [
  ...(await getCollection('notes', ({ data }) => !data.draft)),
  ...(await getCollection('garden', ({ data }) => !data.draft)),
  ...(await getCollection('articles', ({ data }) => !data.draft)),
];
const related = [...getExplicitRelated(entry as AnyEntry, allEntries), ...getTagRelated(entry as AnyEntry, allEntries, 4)].filter(
  (e, i, arr) => arr.findIndex((x) => x.id === e.id) === i
).slice(0, 6);
const upstream = getUpstream(entry as AnyEntry, allEntries);
const relatedIds = new Set(related.map((e) => `${e.collection}/${e.id}`));
const suggestions = getTagRelated(entry as AnyEntry, allEntries, 6)
  .filter((e) => !relatedIds.has(`${e.collection}/${e.id}`))
  .slice(0, 3);
---

<BaseLayout title={title} description={description} image={entry.data.image} type="article">
  <article class="container prose">
    <div class="meta">
      <a href={`/${entry.collection}/`}>{collectionLabel(entry.collection as CollectionName)}</a>
      <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
      {entry.data.updatedDate && <span>Updated {formatDate(entry.data.updatedDate)}</span>}
    </div>
    <h1>{entry.data.title}</h1>
    {entry.data.image && <img class="cover-image" src={entry.data.image} alt={entry.data.title} />}
    {entry.data.description && <p class="lede">{entry.data.description}</p>}
    {entry.data.tags.length > 0 && (
      <div class="tags" aria-label="Tags" style="margin-top: 8px;">
        {entry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    )}
    <div class="garden-cta">
      <a href="/garden/">🌱 在数字花园中查看关联</a>
    </div>
    <Content />
    <footer class="prose-footer">
      {(related.length > 0 || upstream.length > 0) && (
        <nav class="related-notes" aria-label="Related notes">
          {upstream.length > 0 && (
            <div class="related-group">
              <h3>← 上游知识</h3>
              <div class="related-links">
                {upstream.map((r) => <a href={getEntryUrl(r)}>{r.data.title}</a>)}
              </div>
            </div>
          )}
          {related.length > 0 && (
            <div class="related-group">
              <h3>→ 相关笔记</h3>
              <div class="related-links">
                {related.map((r) => <a href={getEntryUrl(r)}>{r.data.title}</a>)}
              </div>
            </div>
          )}
        </nav>
      )}
      {suggestions.length > 0 && (
        <div class="suggestions">
          <p class="suggestions-hint">💡 写作建议：这些标签关联的条目尚未加入 related，可以手动添加：</p>
          <div class="related-links">
            {suggestions.map((r) => (
              <a href={getEntryUrl(r)}>{r.data.title}<span class="suggest-ref"> → related: &quot;{r.collection}/{r.id}&quot;</span></a>
            ))}
          </div>
        </div>
      )}
      <p><a href={getEntryUrl(entry)}>Permalink</a> · <small>内容采用 <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="license" target="_blank">CC BY-SA 4.0 <ArrowUpRight size={12} stroke-width={2} /></a> 许可</small></p>
      <div class="giscus-wrapper"><Giscus /></div>
    </footer>
  </article>
</BaseLayout>

<style>
  .cover-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
    margin: 4px 0 20px;
  }

  .related-notes {
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .related-group {
    margin-bottom: 14px;
  }

  .related-group h3 {
    margin: 0 0 8px;
    font-size: 0.9rem;
    color: var(--muted);
    font-weight: 600;
  }

  .related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .related-links a {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 12px;
    font-size: 0.9rem;
    text-decoration: none;
    background: var(--bg-soft);
  }

  .related-links a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .garden-cta {
    margin: 12px 0 20px;
  }

  .garden-cta a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    border: 1px dashed var(--line);
    border-radius: 999px;
    padding: 4px 12px;
    transition: all 0.15s;
  }

  .garden-cta a:hover {
    border-color: var(--accent);
    color: var(--accent);
    border-style: solid;
  }

  .suggestions {
    margin: 0 0 20px;
    padding: 14px 16px;
    border: 1px dashed var(--line);
    border-radius: 10px;
    background: var(--bg-soft);
  }

  .suggestions-hint {
    margin: 0 0 10px;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .suggest-ref {
    display: block;
    font-size: 0.72rem;
    color: var(--muted);
    font-weight: 400;
    font-family: var(--font-mono, monospace);
  }

  .suggestions .related-links a {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 6px 14px;
    border-radius: 10px;
  }
</style>
