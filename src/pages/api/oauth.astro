---
try {
  const code = Astro.url.searchParams.get('code');

  if (!code) {
    // Redirect to GitHub OAuth - skip for now, just confirm Astro globals work
    return new Response('step1: astro.url works, no code param | origin=' + Astro.url.origin, {
      headers: { 'Content-Type': 'text/plain; charset=utf-8' },
    });
  }

  return new Response('step2: got code=' + code, {
    headers: { 'Content-Type': 'text/plain; charset=utf-8' },
  });
} catch (e) {
  return new Response('ERROR: ' + e, {
    status: 500,
    headers: { 'Content-Type': 'text/plain; charset=utf-8' },
  });
}
---
