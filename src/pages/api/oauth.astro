---
// Decap CMS GitHub OAuth callback
// Flow: redirect to GitHub → receive code → exchange for token → postMessage back to opener

const url = Astro.url;
const code = url.searchParams.get('code');
const redirectUri = url.origin + '/api/oauth';

// Access Cloudflare Worker environment variables
const env = (Astro.locals as any)?.runtime?.env ?? {};

if (!code) {
  // Step 1: no code → redirect to GitHub for authorization
  const clientId = env.GITHUB_CLIENT_ID;
  if (!clientId) {
    return new Response(
      `<!DOCTYPE html><html><body style="font-family:sans-serif;padding:2rem">
        <h1>❌ Missing GITHUB_CLIENT_ID</h1>
        <p>Run: <code>wrangler secret put GITHUB_CLIENT_ID</code></p>
      </body></html>`,
      { status: 500, headers: { 'Content-Type': 'text/html; charset=utf-8' } },
    );
  }

  const gh = new URL('https://github.com/login/oauth/authorize');
  gh.searchParams.set('client_id', clientId);
  gh.searchParams.set('scope', 'repo,user');
  gh.searchParams.set('redirect_uri', redirectUri);
  return Astro.redirect(gh.toString(), 302);
}

// Step 2: exchange code for access token
const clientSecret = env.GITHUB_CLIENT_SECRET;
if (!clientSecret) {
  return new Response(
    `<!DOCTYPE html><html><body style="font-family:sans-serif;padding:2rem">
      <h1>❌ Missing GITHUB_CLIENT_SECRET</h1>
      <p>Run: <code>wrangler secret put GITHUB_CLIENT_SECRET</code></p>
    </body></html>`,
    { status: 500, headers: { 'Content-Type': 'text/html; charset=utf-8' } },
  );
}

let accessToken: string;
try {
  const tokenRes = await fetch('https://github.com/login/oauth/access_token', {
    method: 'POST',
    headers: { Accept: 'application/json', 'Content-Type': 'application/json' },
    body: JSON.stringify({ client_id: env.GITHUB_CLIENT_ID, client_secret: clientSecret, code }),
  });
  const data: any = await tokenRes.json();

  if (data.error || !data.access_token) {
    return new Response(
      `<!DOCTYPE html><html><body style="font-family:sans-serif;padding:2rem">
        <h1>❌ Auth Failed</h1>
        <p>${data.error_description || data.error || 'Unknown error'}</p>
      </body></html>`,
      { status: 400, headers: { 'Content-Type': 'text/html; charset=utf-8' } },
    );
  }
  accessToken = data.access_token;
} catch (err: any) {
  return new Response(
    `<!DOCTYPE html><html><body style="font-family:sans-serif;padding:2rem">
      <h1>❌ Error</h1><p>${err.message}</p>
    </body></html>`,
    { status: 500, headers: { 'Content-Type': 'text/html; charset=utf-8' } },
  );
}

// Step 3: post token back to Decap CMS opener window
const payload = JSON.stringify({ token: accessToken, provider: 'github' });
return new Response(
  `<!DOCTYPE html>
<html><head><title>Signing in…</title></head><body>
<script>
(function(){
  if (window.opener) {
    window.opener.postMessage(${payload}, window.opener.location.origin);
    window.close();
  } else {
    document.body.innerHTML='<p style="font-family:sans-serif;padding:2rem">✅ Done — close this tab.</p>';
  }
})();
</script></body></html>`,
  { headers: { 'Content-Type': 'text/html; charset=utf-8' } },
);
---
