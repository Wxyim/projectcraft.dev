---
import { env } from 'cloudflare:workers';

const url = Astro.url;
const code = url.searchParams.get('code');

if (!code) {
  const gh = new URL('https://github.com/login/oauth/authorize');
  gh.searchParams.set('client_id', env.GITHUB_CLIENT_ID || '');
  gh.searchParams.set('scope', 'repo,user');
  gh.searchParams.set('redirect_uri', url.origin + '/api/oauth');
  return new Response(null, { status: 302, headers: { Location: gh.toString() } });
}

let html = '';
try {
  const res = await fetch('https://github.com/login/oauth/access_token', {
    method: 'POST',
    headers: { Accept: 'application/json', 'Content-Type': 'application/json' },
    body: JSON.stringify({ client_id: env.GITHUB_CLIENT_ID, client_secret: env.GITHUB_CLIENT_SECRET, code }),
  });
  const data = await res.json();

  if (data.error || !data.access_token) {
    html = '<h1>Auth Failed</h1><p>' + (data.error_description || data.error || '') + '</p>';
  } else {
    const p = JSON.stringify({ token: data.access_token, provider: 'github' });
    html = `<script>
      (function(){
        var d = ${p};
        document.body.innerHTML = '<p style="font-family:sans-serif;padding:2rem">✅ Authorized — closing...</p>';
        if (window.opener) {
          window.opener.postMessage(d, '*');
          setTimeout(function(){ window.close(); }, 500);
        }
      })();
    </script>`;
  }
} catch (e) {
  html = '<h1>Error</h1><p>' + e.message + '</p>';
}

return new Response('<!DOCTYPE html><html><body style="font-family:sans-serif;padding:2rem">' + html + '</body></html>', {
  headers: { 'Content-Type': 'text/html; charset=utf-8' },
});
---
