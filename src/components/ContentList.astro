---
import { collectionLabel, formatDate, getEntryUrl, type AnyEntry } from '@/utils/content';

interface Props {
  entries: AnyEntry[];
  showCollection?: boolean;
  showGardenLink?: boolean;
  allEntries?: AnyEntry[];
}

const { entries, showCollection = false, showGardenLink = false, allEntries } = Astro.props;

function daysAgo(date: Date): string {
  const diff = Math.floor((Date.now() - date.valueOf()) / 86400000);
  if (diff === 0) return '今天打理';
  if (diff === 1) return '1 天前打理';
  return `${diff} 天前打理`;
}

function getConnCount(entry: AnyEntry, all: AnyEntry[]): number {
  if (!all || all.length === 0) return 0;
  const tags = new Set(entry.data.tags);
  if (tags.size === 0) return 0;
  const seen = new Set<string>();
  for (const e of all) {
    if (e.id === entry.id) continue;
    if (e.data.tags.some((t) => tags.has(t))) seen.add(`${e.collection}/${e.id}`);
    if ((e.data.related ?? []).some((r) => r === entry.id || r === `${entry.collection}/${entry.id}`)) seen.add(`${e.collection}/${e.id}`);
  }
  return seen.size;
}
---

<div class="entry-list">
  {entries.map((entry) => {
    const lastDate = entry.data.updatedDate ?? entry.data.pubDate;
    const tended = entry.data.updatedDate ? daysAgo(entry.data.updatedDate) : '';
    const conns = allEntries ? getConnCount(entry, allEntries) : null;
    return (
    <article class="entry">
      <div class="meta">
        <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
        {showCollection && <span>{collectionLabel(entry.collection)}</span>}
      </div>
      <h2>
        <a href={getEntryUrl(entry)}>{entry.data.title}</a>
        {tended && <span class="tended-badge" title={formatDate(entry.data.updatedDate!)}>{tended}</span>}
        {showGardenLink && conns !== null && conns > 0 && <span class="conn-badge" title={`${conns} 个关联条目`}>{conns}</span>}
      </h2>
      {entry.data.description && <p>{entry.data.description}</p>}
      {entry.data.tags.length > 0 && (
        <div class="tags" aria-label="Tags">
          {entry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </article>
    );
  })}
  {showGardenLink && (
    <div class="garden-link">
      <a href="/garden/#garden-tabs">🌱 在数字花园中浏览关联 →</a>
    </div>
  )}
</div>

<style>
  .tended-badge {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 400;
    margin-left: 8px;
    white-space: nowrap;
  }
  .tag-count-badge {
    font-size: 0.7rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 1px 7px;
    border-radius: 999px;
    font-weight: 600;
    margin-left: 8px;
    white-space: nowrap;
  }
  .conn-badge {
    font-size: 0.7rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 1px 7px;
    border-radius: 999px;
    font-weight: 650;
    margin-left: 8px;
    white-space: nowrap;
  }

  .garden-link {
    margin-top: 24px;
    text-align: center;
  }

  .garden-link a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.9rem;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 20px;
    transition: all 0.15s;
  }

  .garden-link a:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
  }
</style>
